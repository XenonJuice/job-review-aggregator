{
  "name": "job-review-aggregator",
  "version": "1.0.0",
  "description": "",
  "main": "desktop/app.js",
  "scripts": {
    "build": "npm run build:server && npm run build:web",
    "build:server": "tsc -p backend/tsconfig.json",
    "build:web": "tsc -p frontend/tsconfig.json --noEmit && vite build --config frontend/vite.config.ts",
    "api": "npm run build:server && node dist/backend/server/index.js",
    "web": "vite --config frontend/vite.config.ts",
    "desktop:dev": "concurrently -k -n api,web,desktop -c blue,green,magenta \"npm run api\" \"npm run web\" \"node desktop/start-dev.js\"",
    "pack:mac": "npm run build && electron-builder --mac dir",
    "test": "npm run build && node --test tests/*.test.js"
  },
  "build": {
    "appId": "com.local.job-review-aggregator",
    "productName": "Job Review Aggregator",
    "directories": {
      "output": "release"
    },
    "files": [
      "desktop/**/*",
      "backend/src/storage/schema.sql",
      "dist/**/*",
      "package.json"
    ],
    "mac": {
      "target": [
        "dir"
      ]
    }
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^10.0.3",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.3",
    "typescript": "^5.5.3",
    "vite": "^8.0.16"
  },
  "private": true,
  "dependencies": {
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "lucide-react": "^1.18.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  }
}
