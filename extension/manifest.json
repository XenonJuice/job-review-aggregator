{
  "manifest_version": 3,
  "name": "Job Review Aggregator - 転職会議",
  "version": "0.1.0",
  "description": "将当前账号有权查看的転職会議评论导入本地分析程序。",
  "permissions": ["storage"],
  "host_permissions": [
    "https://jobtalk.jp/*",
    "http://localhost:3000/*",
    "http://127.0.0.1:3000/*"
  ],
  "action": {
    "default_title": "导入転職会議评论",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  }
}
